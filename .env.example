# ─── SERVER-SIDE SECRETS (Vercel env vars — NEVER commit real values) ─────────
# Copy to .env and fill in your actual keys

# GitHub
GITHUB_TOKEN=github_pat_...
GITHUB_USERNAME=your-username

# Vercel
VERCEL_API_KEY=vcp_...
VERCEL_TEAM_ID=                         # optional, for team accounts

# Stripe
STRIPE_SECRET_KEY=sk_live_...           # sk_test_... for dev
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend — 3,000/mo free)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Gumroad
GUMROAD_ACCESS_TOKEN=...

# Content Publishing
DEVTO_API_KEY=...
HASHNODE_TOKEN=...
HASHNODE_PUBLICATION_ID=...

# Analytics
POSTHOG_PERSONAL_API_KEY=phx_...        # server-only read key

# Database (Supabase — 500MB free)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=...                # server-only admin key

# ─── Viral Distribution Channels (100% autonomous — no human needed) ──────────

# Twitter/X — auto-schedule threads (free.typefully.com → Settings → API)
TYPEFULLY_API_KEY=

# Reddit — auto-post to subreddits (reddit.com/prefs/apps → create app: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password

# LinkedIn — auto-post articles (developers.linkedin.com → Auth token via OAuth)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:XXXXXX

# Medium — auto-publish articles (medium.com/me/settings → Integration Tokens)
MEDIUM_INTEGRATION_TOKEN=
MEDIUM_USER_ID=                         # auto-fetched if blank

# Hacker News — auto Show HN post (your HN account credentials)
HN_USERNAME=
HN_PASSWORD=

# Telegram Channel — broadcast launches (t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@yourchannel         # or numeric ID like -1001234567890

# IndexNow / Bing — instant search indexing (bing.com/indexnow → Get API key)
BING_INDEXNOW_KEY=

# Chrome Extension (optional — lib/chrome.js)
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=

# ProductHunt API token
PH_TOKEN=

# SEO / SERP
SERP_API_KEY=...                        # SerpAPI or ValueSERP (free tier available)
GOOGLE_CSE_ID=...                       # Google Custom Search Engine ID
GOOGLE_CSE_API_KEY=...                  # Google API key for CSE

# Twitter / X (optional — for trend signals)
TWITTER_BEARER_TOKEN=...

# ─── Failure Alerts ──────────────────────────────────────────────────────────
# Slack Incoming Webhook — get at: https://api.slack.com/messaging/webhooks
# Create App → Incoming Webhooks → Activate → Add New Webhook to Workspace
# If set: all agent failures post to your Slack channel. If not set: email fallback via Resend.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ─── BROWSER-SAFE KEYS (paste into index.html ENV object) ────────────────────
# These go in the browser dashboard — acceptable for personal use dashboard
# ANTHROPIC_API_KEY=sk-ant-...          # dangerous-direct-browser-access header
# GROQ_API_KEY=gsk_...                  # CORS-enabled, 14,400 req/day free
# GEMINI_API_KEY=AIza...                # CORS-enabled, free embeddings
# PINECONE_API_KEY=pcsk_...             # CORS-enabled, 100k vectors free
# PINECONE_HOST=https://xxx.pinecone.io
# YOUTUBE_API_KEY=AIza...               # CORS-enabled, read-only
# POSTHOG_WRITE_KEY=phc_...             # write-only, safe in browser
# SUPABASE_ANON_KEY=eyJ...              # safe with RLS enabled
